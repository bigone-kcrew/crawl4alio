# 이 파일을 .env.api 로 복사한 뒤 값을 채우고, 실행 전 `source .env.api` 하세요.
# 아래 서비스들은 이 저장소에 포함되어 있지 않습니다. 직접 배포하거나(Docker 등)
# 대체 구현을 붙여야 합니다. 자세한 내용은 docs/CONVERSION.md 참고.

# --- Crawl4AI (ALIO 상세페이지 크롤링, download_documents_advanced.js) ---
# 전체 crawl 엔드포인트. 미설정 시 http://localhost:11235/crawl
CRAWL4AI_URL=http://localhost:11235/crawl
# collect_legal_corpus.js 전용: host:port 형태
CRAWL4AI_HOST=localhost:11235
# crawl4ai 서버에 인증이 걸려 있는 경우의 Bearer 토큰
CRAWL4AI_API_TOKEN=

# --- kordoc (HWP/HWPX/PDF/XLS(X)/DOCX -> Markdown 1차 변환기) ---
# 기본은 내장 npm(in-process)이라 설정 불필요. 별도 서버를 쓸 때만 지정.
# KORDOC_PARSE_URL=http://localhost:3400/parse
# KORDOC_URL=http://localhost:3400/parse

# --- markitdown (선택 폴백 — kordoc이 대부분 커버하므로 보통 불필요) ---
# MARKITDOWN_PARSE_URL=http://localhost:3410/parse

# --- PaddleOCR (스캔 PDF/이미지 OCR, 최종 폴백) ---
# convert_ocr_needed.js, convert_reference_docs.js, ocrtomarkdown/
PADDLEOCR_PARSE_URL=http://localhost:13430/parse
# collect_legal_corpus.js 전용 변수명
PADDLEOCR_URL=http://localhost:13430/parse

# --- law.go.kr Open API ---
# https://open.law.go.kr 에서 발급받은 이용자 ID(OC 파라미터).
# collect_legal_corpus.js는 OPENAPILAWKEY를, enrich_legal_ministry.js는 LAW_OC를 읽습니다.
OPENAPILAWKEY=
LAW_OC=

# --- 선택: 동시성/타임아웃 튜닝 ---
# CONCURRENT=5
# CONCURRENT_LARGE=2
# LARGE_FILE_MB=10
# CHECKPOINT_INTERVAL=100
